---
layout: false
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {# Homepage #}
  <url>
    <loc>{{ site.origin }}{{ '/' | url }}</loc>
    <lastmod>{{ buildInfo.getGitLastModified('src/index.njk') or buildInfo.builtAtUTC }}</lastmod>
    <priority>1.0</priority>
    <changefreq>monthly</changefreq>
  </url>

  {# Main navigation pages #}
  <url>
    <loc>{{ site.origin }}{{ '/texts/' | url }}</loc>
    <lastmod>{{ buildInfo.getGitLastModified('src/texts.njk') or buildInfo.builtAtUTC }}</lastmod>
    <priority>0.9</priority>
    <changefreq>weekly</changefreq>
  </url>
  <url>
    <loc>{{ site.origin }}{{ '/by-figure/' | url }}</loc>
    <lastmod>{{ buildInfo.getGitLastModified('src/by-figure.njk') or buildInfo.builtAtUTC }}</lastmod>
    <priority>0.9</priority>
    <changefreq>weekly</changefreq>
  </url>
  <url>
    <loc>{{ site.origin }}{{ '/search/' | url }}</loc>
    <lastmod>{{ buildInfo.builtAtUTC }}</lastmod>
    <priority>0.7</priority>
    <changefreq>monthly</changefreq>
  </url>
  <url>
    <loc>{{ site.origin }}{{ '/updates/' | url }}</loc>
    <lastmod>{{ buildInfo.getGitLastModified('src/_data/updates.json') or buildInfo.builtAtUTC }}</lastmod>
    <priority>0.7</priority>
    <changefreq>weekly</changefreq>
  </url>
  <url>
    <loc>{{ site.origin }}{{ '/about/' | url }}</loc>
    <lastmod>{{ buildInfo.getGitLastModified('src/about.njk') or buildInfo.builtAtUTC }}</lastmod>
    <priority>0.6</priority>
    <changefreq>monthly</changefreq>
  </url>
  <url>
    <loc>{{ site.origin }}{{ '/license/' | url }}</loc>
    <lastmod>{{ buildInfo.getGitLastModified('src/license.njk') or buildInfo.builtAtUTC }}</lastmod>
    <priority>0.4</priority>
    <changefreq>yearly</changefreq>
  </url>
  <url>
    <loc>{{ site.origin }}{{ '/privacy/' | url }}</loc>
    <lastmod>{{ buildInfo.getGitLastModified('src/privacy.njk') or buildInfo.builtAtUTC }}</lastmod>
    <priority>0.4</priority>
    <changefreq>yearly</changefreq>
  </url>
  <url>
    <loc>{{ site.origin }}{{ '/contact/' | url }}</loc>
    <lastmod>{{ buildInfo.getGitLastModified('src/contact.njk') or buildInfo.builtAtUTC }}</lastmod>
    <priority>0.5</priority>
    <changefreq>yearly</changefreq>
  </url>

  {# Language category pages — dynamically from languages.json #}
  {% for langSlug, langEntry in languages %}
  <url>
    <loc>{{ site.origin }}{{ ('/texts/' + langSlug + '/') | url }}</loc>
    <lastmod>{{ buildInfo.builtAtUTC }}</lastmod>
    <priority>0.8</priority>
    <changefreq>weekly</changefreq>
  </url>
  {% endfor %}

  {# By-figure pages — dynamically from figureCatalogKeys.json #}
  {% for figSlug in figureCatalogKeys %}
  <url>
    <loc>{{ site.origin }}{{ ('/by-figure/' + figSlug + '/') | url }}</loc>
    <lastmod>{{ buildInfo.builtAtUTC }}</lastmod>
    <priority>0.8</priority>
    <changefreq>monthly</changefreq>
  </url>
  {% endfor %}

  {# All text pages (book indexes + chapter pages) #}
  {% for item in collections.all %}
    {% if item.data.tags and "texts" in item.data.tags and not item.data.draft %}
    <url>
      <loc>{{ site.origin }}{{ item.url | url }}</loc>
      <lastmod>{{ buildInfo.getGitLastModified(item.inputPath) or buildInfo.builtAtUTC }}</lastmod>
      <priority>{% if item.data.pageNumber == 0 or not item.data.pageNumber %}0.8{% else %}0.7{% endif %}</priority>
      <changefreq>monthly</changefreq>
    </url>
    {% endif %}
  {% endfor %}
</urlset>
