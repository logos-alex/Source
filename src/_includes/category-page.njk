{% extends "base.njk" %}

{% block content %}
  <div class="text-main">
    <h1>{{ title }}</h1>

    {% if source or figure %}
      {% set sourceHebrew = languages[source] or source %}
      {% set figureHebrew = figures[figure] or figure %}
      <p><em>מקור: {{ sourceHebrew or 'לא מצוין' }} | ייחוס: {{ figureHebrew or 'לא מצוין' }}</em></p>
    {% endif %}

    {{ content | safe }}
  </div>

  <div class="table-of-contents c-section-divider">
    <h3>תוכן העניינים:</h3>
    {% set pagesInBook = collections.all | bookPages(page.url, book) %}
    {% set chapterPages = collections.all | bookPages(page.url, book, false) %}
    <ul>
      {% for item in chapterPages %}
        {% if item.url != page.url %}
          <li><a href="{{ item.url | url }}">{{ item | chapterDisplayTitle(book) }}</a></li>
        {% endif %}
      {% endfor %}
    </ul>

    {% if chapterPages.length == 0 %}
      <p class="c-muted--italic">פרקי החיבור יתווספו בהמשך.</p>
    {% endif %}
  </div>

  {% if chapterPages.length > 0 %}
    <nav class="pagination">
      <div class="toc-dropdown">
        <a href="{{ page.url | url }}" class="home-link">📖 תוכן העניינים</a>
        <div class="toc-dropdown-content">
          <div class="toc-dropdown-header">פרקים בטקסט</div>
          <ul>
            {% for item in chapterPages %}
              <li><a href="{{ item.url | url }}">{{ item | chapterDisplayTitle(book) }}</a></li>
            {% endfor %}
          </ul>
        </div>
      </div>

      <a href="{{ chapterPages[0].url | url }}" class="next">התחל קריאה ←</a>
    </nav>
  {% endif %}


  {# --- אזור התגובות של Disqus (opt-in) --- #}
  {% include "disqus.njk" %}

{% endblock %}
