{% extends "base.njk" %}

{% block content %}
  <article class="text-main">
    <header class="text-header">
      <h1>{{ title }}</h1>
      {% if source or figure %}
        {% set sourceHebrew = languages[source] or source %}
        {% set figureHebrew = figures[figure] or figure %}
        <p class="text-meta">
          {% if sourceHebrew %}<span class="text-meta__item"><span class="text-meta__label">מקור:</span> {{ sourceHebrew }}</span>{% endif %}
          {% if sourceHebrew and figureHebrew %}<span class="text-meta__sep" aria-hidden="true">·</span>{% endif %}
          {% if figureHebrew %}<span class="text-meta__item"><span class="text-meta__label">ייחוס:</span> {{ figureHebrew }}</span>{% endif %}
        </p>
      {% endif %}
    </header>

    <div class="text-content">
      {{ content | safe }}
    </div>
  </article>

  <div class="table-of-contents c-section-divider">
    <h3>העמודים</h3>

    {% set pagesInBook = collections.all | bookPages(page.url, book) %}
    {% set byVersion = pagesInBook | groupby("data.version") %}

    {% if pagesInBook.length %}
      {% for versionGroup in byVersion %}
        {% set versionKey = versionGroup[0] %}
        {% set versionPages = versionGroup[1] %}

        {% if byVersion.length > 1 %}
          <h4 class="table-of-contents__version-heading">
            {% if versionKey == 'a' %}נוסח א'{% elif versionKey == 'b' %}נוסח ב'{% else %}נוסח עיקרי{% endif %}
          </h4>
        {% endif %}

        <ul>
          {% for pageItem in versionPages %}
            <li><a href="{{ pageItem.url | url }}">{{ pageItem.data.title }}</a></li>
          {% endfor %}
        </ul>
      {% endfor %}
    {% else %}
      <p class="c-muted--italic">פרקי החיבור יתווספו בהמשך.</p>
    {% endif %}
  </div>

    {# --- אזור התגובות --- #}
  {% include "disqus.njk" %}
{% endblock %}
