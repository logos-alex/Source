{% extends "base.njk" %}

{% block content %}
  <div class="text-main">
    {# מציג את הכותרת ואת תוכן המבוא עצמו #}
    <h1>{{ title }}</h1>
    {% if source or figure %}
      {% set sourceHebrew = languages[source] or source %}
      {% set figureHebrew = figures[figure] or figure %}
      <p><em>מקור: {{ sourceHebrew or 'לא מצוין' }} | ייחוס: {{ figureHebrew or 'לא מצוין' }}</em></p>
    {% endif %}
    {{ content | safe }}
  </div>

  {# --- תוכן העניינים האוטומטי עבור ספרים ללא תוכן ידני --- #}
  <div class="table-of-contents c-section-divider">
    <h3>העמודים:</h3>

    {% set pagesInBook = collections.all | bookPages(page.url, book) %}
    {% set byVersion = pagesInBook | groupby("data.version") %}

    {% if pagesInBook.length %}
      {% for versionGroup in byVersion %}
        {% set versionKey = versionGroup[0] %}
        {% set versionPages = versionGroup[1] %}

        {% if byVersion.length > 1 %}
          <h4 class="table-of-contents__version-heading">
            {% if versionKey == 'a' %}נוסח א'{% elif versionKey == 'b' %}נוסח ב'{% else %}נוסח עיקרי{% endif %}
          </h4>
        {% endif %}

        <ul>
          {% for pageItem in versionPages %}
            <li>
              <a href="{{ pageItem.url | url }}">{{ pageItem.data.title }}</a>
            </li>
          {% endfor %}
        </ul>
      {% endfor %}
    {% else %}
      <p class="c-muted--italic">פרקי החיבור יתווספו בהמשך.</p>
    {% endif %}
  </div>

  {# --- אזור התגובות של Disqus --- #}
  <div id="comments-section" class="c-section-divider">
    <h3>תגובות</h3>
    {% if site.disqusShortname %}
      <div id="disqus_thread"></div>
      <script>
          var disqus_config = function () {
              this.page.url = "{{ site.origin }}{{ page.url | url }}";
              this.page.identifier = "{{ page.url | url }}";
          };
          (function() {
              var d = document, s = d.createElement('script');
              s.src = 'https://{{ site.disqusShortname }}.disqus.com/embed.js';
              s.setAttribute('data-timestamp', +new Date());
              (d.head || d.body).appendChild(s);
          })();
      </script>
      <noscript>יש לאפשר JavaScript כדי לצפות ב<a href="https://disqus.com/?ref_noscript">תגובות המופעלות על ידי Disqus.</a></noscript>
    {% else %}
      <p class="c-muted">מערכת התגובות כבויה כרגע בהגדרות האתר.</p>
    {% endif %}
  </div>
{% endblock %}
