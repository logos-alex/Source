{% extends "base.njk" %}

{% block content %}
  <!-- Reading Progress Bar -->
  <div class="reading-progress">
    <div class="reading-progress-bar" id="readingProgress"></div>
  </div>
  
  <div class="text-main" data-pagefind-body>
    {% if book == 'apoc-daniel-syriac' and pageNumber != 0 %}
      <h1 data-pagefind-meta="title">פרק {{ pageNumber | toHebrewNumeral }}</h1>
    {% else %}
      <h1 data-pagefind-meta="title">{{ title }}</h1>
    {% endif %}
    
    {% if source or figure %}
      {% set sourceHebrew = languages[source] or source %}
      {% set figureHebrew = figures[figure] or figure %}
      <p><em>מקור: {{ sourceHebrew or 'לא מצוין' }} | ייחוס: {{ figureHebrew or 'לא מצוין' }}</em></p>
    {% endif %}
    
    <div class="text-content {% if book == 'apoc-daniel-syriac' and pageNumber != 0 %}parallel-layout{% endif %}">
      {% if book == "apoc-daniel-syriac" and pageNumber != 0 %}
        {% set split = content | splitParallelContent %}
        {% set sourcePart = split.source %}
        {% set translationPart = split.translation %}

        {% if not translationPart %}
          {% set translationPart = '<p>תרגום עברי לפרק זה יושלם בהמשך.</p>' %}
        {% endif %}

        <div class="column-source">
          {{ sourcePart | safe }}
        </div>
        <div class="column-translation">
          {{ translationPart | safe }}
        </div>
      {% else %}
        {{ content | safe }}
      {% endif %}
    </div>
  </div>
  
  <script>
    window.addEventListener('scroll', function() {
      const windowHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = (window.scrollY / windowHeight) * 100;
      const progressEl = document.getElementById('readingProgress');
      if (progressEl) {
        progressEl.style.width = scrolled + '%';
      }
    });
  </script>

  {% if pageNumber != 0 and notes %}
    <div class="footnotes">
      <h3>הערות וביאורים</h3>
      <ul>
        {% for note in notes %}
          <li id="note-{{ loop.index }}">{{ note | safe }}</li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}

  {# --- ניווט בין עמודים (עם כפתור חזרה לתוכן העניינים) --- #}
  {% set pagesInBook = collections.all | bookPages(page.url, book) %}
  {% set chapterPages = collections.all | bookPages(page.url, book, false) %}
  {% set currentPageIndex = pagesInBook | findIndexByUrl(page.url) %}
  {% set tocPage = (pagesInBook | selectattr("data.pageNumber", "equalto", 0) | list | first) or pagesInBook[0] %}
  
  <nav class="pagination">
    {# כפתור "הקודם" (מופיע מימין) - צריך חץ ימינה #}
    {% if currentPageIndex > 0 %}
      {% set prevPage = pagesInBook[currentPageIndex - 1] %}
      <a href="{{ prevPage.url | url }}" class="prev">→ {{ prevPage | chapterDisplayTitle(book) }}</a>
    {% endif %}

    {# === כפתור תוכן העניינים (תמיד מופיע בניווט הקבוע) === #}
    {% if book %}
    <div class="toc-dropdown">
      <a href="{{ tocPage.url | url }}" class="home-link">📖 תוכן העניינים</a>
      <div class="toc-dropdown-content">
        <div class="toc-dropdown-header">פרקים בטקסט</div>
        <ul>
          {% for item in chapterPages %}
              <li><a href="{{ item.url | url }}">{{ item | chapterDisplayTitle(book) }}</a></li>
            {% endfor %}
        </ul>
      </div>
    </div>
    {% endif %}
    
    {# כפתור "הבא" (מופיע משמאל) - צריך חץ שמאלה #}
    {% if currentPageIndex < pagesInBook.length - 1 %}
      {% set nextPage = pagesInBook[currentPageIndex + 1] %}
      <a href="{{ nextPage.url | url }}" class="next">← {{ nextPage | chapterDisplayTitle(book) }}</a>
    {% endif %}
  </nav>

  {# --- אזור התגובות של Disqus --- #}
  <div id="comments-section" style="margin-top: 40px; padding-top: 20px; border-top: 1px solid var(--border-color);">
    <h3>תגובות</h3>
    {% if site.disqusShortname %}
      <div id="disqus_thread"></div>
      <script>
          var disqus_config = function () {
              this.page.url = "{{ site.origin }}{{ page.url | url }}";
              this.page.identifier = "{{ page.url | url }}";
          };
          (function() {
              var d = document, s = d.createElement('script');
              s.src = 'https://{{ site.disqusShortname }}.disqus.com/embed.js';
              s.setAttribute('data-timestamp', +new Date());
              (d.head || d.body).appendChild(s);
          })();
      </script>
      <noscript>Please enable JavaScript to view the <a href="https://disqus.com/?ref_noscript">comments powered by Disqus.</a></noscript>
    {% else %}
      <p style="color: var(--text-color-muted);">מערכת התגובות כבויה כרגע בהגדרות האתר.</p>
    {% endif %}
  </div>

{% endblock %}
