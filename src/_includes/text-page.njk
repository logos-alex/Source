{% extends "base.njk" %}

{% set bodyClass = "text-page" %}

{% block head_extras %}
  {% set pagesInBook = collections.all | bookPages(page.url, book) %}
  {% set currentPageIndex = pagesInBook | findIndexByUrl(page.url) %}
  {% if currentPageIndex > 0 %}
    {% set prevPage = pagesInBook[currentPageIndex - 1] %}
    <link rel="prev" href="{{ prevPage.url | url }}">
  {% endif %}
  {% if currentPageIndex >= 0 and currentPageIndex < pagesInBook.length - 1 %}
    {% set nextPage = pagesInBook[currentPageIndex + 1] %}
    <link rel="next" href="{{ nextPage.url | url }}">
  {% endif %}
{% endblock %}

{% block content %}
  <div class="reading-progress" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" aria-label="התקדמות הקריאה">
    <div class="reading-progress-bar" id="readingProgress"></div>
  </div>

  <article class="text-main" data-pagefind-body>
    <header class="text-header">
      {% if book | usesHebrewChapterTitles and pageNumber != 0 %}
        <p class="text-header__eyebrow">פרק {{ pageNumber | toHebrewNumeral }}</p>
        <h1 data-pagefind-meta="title">{{ title }}</h1>
      {% else %}
        <h1 data-pagefind-meta="title">{{ title }}</h1>
      {% endif %}

      {% if source or figure %}
        {% set langEntry = languages[source] %}
        {% set sourceHebrew = (langEntry.label if langEntry else source) %}
        {% set figureHebrew = figures[figure] or figure %}
        <p class="text-meta">
          {% if sourceHebrew %}<span class="text-meta__item"><span class="text-meta__label">מקור:</span> {{ sourceHebrew }}</span>{% endif %}
          {% if sourceHebrew and figureHebrew %}<span class="text-meta__sep" aria-hidden="true">·</span>{% endif %}
          {% if figureHebrew %}<span class="text-meta__item"><span class="text-meta__label">ייחוס:</span> {{ figureHebrew }}</span>{% endif %}
        </p>
      {% endif %}
    </header>

    <div class="text-content">
      <div class="text-controls" role="group" aria-label="גודל גופן">
        <span class="text-controls__label">גודל טקסט</span>
        <button class="text-controls__btn is-active" type="button" data-scale="md" aria-pressed="true" aria-label="טקסט רגיל">א</button>
        <button class="text-controls__btn" type="button" data-scale="sm" aria-pressed="false" aria-label="טקסט קטן">א-</button>
        <button class="text-controls__btn" type="button" data-scale="lg" aria-pressed="false" aria-label="טקסט גדול">א+</button>
        <button class="text-controls__btn" type="button" data-scale="xl" aria-pressed="false" aria-label="טקסט גדול מאוד">א++</button>
      </div>
      {% if book | usesHebrewChapterTitles and pageNumber != 0 %}
        {# Parallel layout: try to split on "### תרגום עברי" header or `<hr>` separator. #}
        {% set contentParts = content.split("<h3>תרגום עברי</h3>") %}
        {% if contentParts.length < 2 %}
          {% set contentParts = content.split("<hr>") %}
        {% endif %}
        {% if contentParts.length >= 2 %}
          <div class="parallel-controls" role="group" aria-label="תצוגת מקור">
            <button class="parallel-toggle" type="button" data-parallel-toggle="show" aria-pressed="true">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="12" y1="3" x2="12" y2="21"/></svg>
              <span>מקור + תרגום</span>
            </button>
            <button class="parallel-toggle" type="button" data-parallel-toggle="hide" aria-pressed="false">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
              <span>תרגום בלבד</span>
            </button>
          </div>
          <div class="parallel-layout" data-parallel-container>
            {% set langEntry = languages[source] %}
            {% set colLang = (langEntry.iso if langEntry else source) %}
            <section class="column-source" data-parallel-source lang="{{ colLang }}" aria-label="מקור בשפת המקור">
              {# Strip leading source-side H3 (e.g. "מקור ארמי", "מקור סורי", "מקור יווני") — they are decorative. #}
              {% set sourceHtml = contentParts[0] or "" %}
              {% set sourceHtml = sourceHtml | replace("<h3>מקור ארמי</h3>", "") | replace("<h3>מקור סורי</h3>", "") | replace("<h3>מקור יווני</h3>", "") | replace("<h3>מקור ערבי</h3>", "") | replace("<h3>מקור לטיני</h3>", "") | replace("<h3>מקור סלאבי</h3>", "") | replace("<h3>מקור ארמני</h3>", "") | replace("<h3>מקור געז</h3>", "") | replace("<h3>מקור עברי</h3>", "") %}
              {{ sourceHtml | renderNoteRefs | safe }}
            </section>
            <section class="column-translation" data-parallel-translation aria-label="תרגום עברי">
              <h2 class="column-translation__heading visually-hidden">תרגום עברי</h2>
              {{ (contentParts[1] or "") | renderNoteRefs | safe }}
            </section>
          </div>
        {% else %}
          {{ content | renderNoteRefs | safe }}
        {% endif %}
      {% else %}
        {{ content | renderNoteRefs | safe }}
      {% endif %}
    </div>
  </article>

  {% if pageNumber and pageNumber != 0 and notes %}
    <div class="footnotes">
      <h2 class="footnotes__heading">הערות וביאורים</h2>
      <ul>
        {% for note in notes %}
          <li id="note-{{ loop.index }}">{{ note | renderMarkdownInline | safe }} <a href="#ref-{{ loop.index }}" class="note-backlink" aria-label="חזרה להערה {{ loop.index }}">↩</a></li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}

  {# --- ניווט בין עמודים --- #}
  {% set pagesInBook = collections.all | bookPages(page.url, book) %}
  {% set chapterPages = pagesInBook | rejectattr("data.pageNumber", "equalto", 0) | list %}
  {% set currentPageIndex = pagesInBook | findIndexByUrl(page.url) %}

  <nav class="pagination" aria-label="ניווט בין פרקים">
    {% if currentPageIndex >= 0 and currentPageIndex > 0 %}
      {% set prevPage = pagesInBook[currentPageIndex - 1] %}
      <a href="{{ prevPage.url | url }}" class="prev" rel="prev">→ {{ prevPage | chapterDisplayTitle(book) }}</a>
    {% else %}
      <span aria-hidden="true"></span>
    {% endif %}

    {% if book %}
    <div class="toc-dropdown">
      <a href="{{ page.url | url }}" class="home-link" aria-haspopup="true" aria-expanded="false">תוכן העניינים</a>
      <div class="toc-dropdown-content">
        <div class="toc-dropdown-header">פרקים בטקסט</div>
        <ul>
          {% for item in chapterPages %}
            <li><a href="{{ item.url | url }}">{{ item | chapterDisplayTitle(book) }}</a></li>
          {% endfor %}
        </ul>
      </div>
    </div>
    {% endif %}

    {% if currentPageIndex >= 0 and currentPageIndex < pagesInBook.length - 1 %}
      {% set nextPage = pagesInBook[currentPageIndex + 1] %}
      <a href="{{ nextPage.url | url }}" class="next" rel="next">{{ nextPage | chapterDisplayTitle(book) }} ←</a>
    {% else %}
      <span aria-hidden="true"></span>
    {% endif %}
  </nav>

    {# --- אזור התגובות --- #}
  {% include "disqus.njk" %}

{% endblock %}
