{% extends "base.njk" %}

{% block content %}
  <div class="reading-progress" aria-hidden="true">
    <div class="reading-progress-bar" id="readingProgress"></div>
  </div>

  <article class="text-main" data-pagefind-body>
    <header class="text-header">
      {% if book | usesHebrewChapterTitles and pageNumber != 0 %}
        <p class="text-header__eyebrow">פרק {{ pageNumber | toHebrewNumeral }}</p>
        <h1 data-pagefind-meta="title">{{ title }}</h1>
      {% else %}
        <h1 data-pagefind-meta="title">{{ title }}</h1>
      {% endif %}

      {% if source or figure %}
        {% set sourceHebrew = languages[source] or source %}
        {% set figureHebrew = figures[figure] or figure %}
        <p class="text-meta">
          {% if sourceHebrew %}<span class="text-meta__item"><span class="text-meta__label">מקור:</span> {{ sourceHebrew }}</span>{% endif %}
          {% if sourceHebrew and figureHebrew %}<span class="text-meta__sep" aria-hidden="true">·</span>{% endif %}
          {% if figureHebrew %}<span class="text-meta__item"><span class="text-meta__label">ייחוס:</span> {{ figureHebrew }}</span>{% endif %}
        </p>
      {% endif %}
    </header>

    <div class="text-content">
      <div class="text-controls" role="group" aria-label="גודל גופן">
        <span class="text-controls__label">גודל טקסט</span>
        <button class="text-controls__btn" type="button" data-scale="sm" aria-label="טקסט קטן">א-</button>
        <button class="text-controls__btn is-active" type="button" data-scale="md" aria-label="טקסט רגיל">א</button>
        <button class="text-controls__btn" type="button" data-scale="lg" aria-label="טקסט גדול">א+</button>
        <button class="text-controls__btn" type="button" data-scale="xl" aria-label="טקסט גדול מאוד">א++</button>
      </div>
      {% if book | usesHebrewChapterTitles and pageNumber != 0 %}
        {% set contentParts = content.split("<h3>תרגום עברי</h3>") %}
        {% if contentParts.length < 2 %}
          {% set contentParts = content.split("<hr>") %}
        {% endif %}
        {% if contentParts.length >= 2 %}
          <div class="parallel-controls" role="group" aria-label="תצוגת מקור">
            <button class="parallel-toggle" type="button" data-parallel-toggle="show" aria-pressed="true">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="12" y1="3" x2="12" y2="21"/></svg>
              <span>מקור + תרגום</span>
            </button>
            <button class="parallel-toggle" type="button" data-parallel-toggle="hide" aria-pressed="false">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
              <span>תרגום בלבד</span>
            </button>
          </div>
          <div class="parallel-layout" data-parallel-container>
            <div class="column-source" data-parallel-source>
              {{ (contentParts[0] or "") | replace("<h3>מקור ארמי</h3>", "") | renderNoteRefs | safe }}
            </div>
            <div class="column-translation" data-parallel-translation>
              {{ (contentParts[1] or "") | renderNoteRefs | safe }}
            </div>
          </div>
        {% else %}
          {{ content | renderNoteRefs | safe }}
        {% endif %}
      {% else %}
        {{ content | renderNoteRefs | safe }}
      {% endif %}
    </div>
  </article>

  {% if pageNumber != 0 and notes %}
    <div class="footnotes">
      <h3>הערות וביאורים</h3>
      <ul>
        {% for note in notes %}
          <li id="note-{{ loop.index }}">{{ note | renderMarkdownInline | safe }} <a href="#ref-{{ loop.index }}" class="note-backlink" aria-label="חזרה למיקום ההפניה בגוף הטקסט">↩</a></li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}

  {# --- ניווט בין עמודים --- #}
  {% set pagesInBook = collections.all | bookPages(page.url, book) %}
  {% set chapterPages = collections.all | bookPages(page.url, book, false) %}
  {% set currentPageIndex = pagesInBook | findIndexByUrl(page.url) %}
  {% set tocPage = (pagesInBook | selectattr("data.pageNumber", "equalto", 0) | list | first) or pagesInBook[0] %}

  <nav class="pagination" aria-label="ניווט בין פרקים">
    {% if currentPageIndex > 0 %}
      {% set prevPage = pagesInBook[currentPageIndex - 1] %}
      <a href="{{ prevPage.url | url }}" class="prev">→ {{ prevPage | chapterDisplayTitle(book) }}</a>
    {% else %}
      <span></span>
    {% endif %}

    {% if book %}
    <div class="toc-dropdown">
      <a href="{{ tocPage.url | url }}" class="home-link">תוכן העניינים</a>
      <div class="toc-dropdown-content">
        <div class="toc-dropdown-header">פרקים בטקסט</div>
        <ul>
          {% for item in chapterPages %}
            <li><a href="{{ item.url | url }}">{{ item | chapterDisplayTitle(book) }}</a></li>
          {% endfor %}
        </ul>
      </div>
    </div>
    {% endif %}

    {% if currentPageIndex < pagesInBook.length - 1 %}
      {% set nextPage = pagesInBook[currentPageIndex + 1] %}
      <a href="{{ nextPage.url | url }}" class="next">{{ nextPage | chapterDisplayTitle(book) }} ←</a>
    {% else %}
      <span></span>
    {% endif %}
  </nav>

  {# --- אזור התגובות --- #}
  {% include "disqus.njk" %}

{% endblock %}
