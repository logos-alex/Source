<!DOCTYPE html>
<html lang="he" dir="rtl" id="htmlRoot">
<head>
    {% set sitePrefix = (site.pathPrefix or '/Source/') %}
    {% set fonts = site.fonts or {} %}
    {% set thirdParty = site.thirdParty or {} %}
    {% set analytics = thirdParty.analytics or {} %}
    {% set clarity = thirdParty.clarity or {} %}
    {% set disqus = thirdParty.disqus or {} %}
    {% set translate = thirdParty.translate or {} %}
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | LOGIA — אוצר הכתבים הגנוזים</title>

    <!-- Accessibility -->
    <meta name="color-scheme" content="light dark">

    <!-- PWA / Mobile -->
    <meta name="theme-color" content="#1C1813" media="(prefers-color-scheme: dark)">
    <meta name="theme-color" content="#FAF6EE" media="(prefers-color-scheme: light)">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="LOGIA">
    <meta name="mobile-web-app-capable" content="yes">
    <link rel="manifest" href="{{ '/manifest.json' | url }}">

    <!-- SEO & Meta Tags -->
    <meta name="description" content="{% if description %}{{ description }}{% elif pageNumber and title %}{{ title }} — טקסט ותרגום באתר LOGIA — אוצר הכתבים הגנוזים.{% else %}מסע אל הכתבים הגנוזים והאבודים של המסורת היהודית. תרגומים, ביאורים ועיון בטקסטים שנדחקו אל השוליים.{% endif %}">
    <meta name="keywords" content="LOGIA, כתבים גנוזים, אפוקריפה, ספרים חיצוניים, יהדות, בית שני, מינות, גנוסטיקה, קבלה, מיסטיקה, דניאל, אברהם, זרובבל, עזרא, ישעיהו, אליהו">
    <meta name="author" content="LOGIA — אוצר הכתבים הגנוזים">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="{{ site.origin }}{{ page.url | url }}">

    <!-- Open Graph Tags for Social Media -->
    {% set ogImageUrl = site.origin ~ site.pathPrefix ~ 'assets/og-image.png' %}
    <meta property="og:type" content="{% if pageNumber == 0 %}book{% else %}article{% endif %}">
    <meta property="og:title" content="{{ title }} | LOGIA — אוצר הכתבים הגנוזים">
    <meta property="og:description" content="{% if description %}{{ description }}{% else %}מסע אל הכתבים הגנוזים והאבודים של המסורת היהודית. תרגומים, ביאורים ועיון בטקסטים שנדחקו אל השוליים.{% endif %}">
    <meta property="og:url" content="{{ site.origin }}{{ page.url | url }}">
    <meta property="og:site_name" content="LOGIA — אוצר הכתבים הגנוזים">
    <meta property="og:locale" content="he_IL">
    <meta property="og:image" content="{{ ogImageUrl }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="לוגו LOGIA — אוצר הכתבים הגנוזים, חותם מעגלי עם האות למדא על רקע שנהב-ברונזה">

    <!-- Twitter/X Tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title }} | LOGIA — אוצר הכתבים הגנוזים">
    <meta name="twitter:description" content="{% if description %}{{ description }}{% else %}מסע אל הכתבים הגנוזים והאבודים של המסורת היהודית. תרגומים, ביאורים ועיון בטקסטים שנדחקו אל השוליים.{% endif %}">
    <meta name="twitter:url" content="{{ site.origin }}{{ page.url | url }}">
    <meta name="twitter:image" content="{{ ogImageUrl }}">
    <meta name="twitter:image:alt" content="לוגו LOGIA — אוצר הכתבים הגנוזים">

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "{% if pageNumber == 0 %}Book{% else %}Article{% endif %}",
      "name": "{{ title }}",
      "description": "{% if description %}{{ description }}{% else %}מסע אל הכתבים הגנוזים והאבודים של המסורת היהודית. תרגומים, ביאורים ועיון בטקסטים שנדחקו אל השוליים.{% endif %}",
      "url": "{{ site.origin }}{{ page.url | url }}",
      "inLanguage": "he",
      "author": {
        "@type": "Organization",
        "name": "LOGIA — אוצר הכתבים הגנוזים"
      }
    }
    </script>
    {% if page.url == '/' %}
    {# WebSite + Organization structured data — only on homepage #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "LOGIA — אוצר הכתבים הגנוזים",
      "alternateName": "LOGIA",
      "url": "{{ site.origin }}{{ site.pathPrefix }}",
      "inLanguage": "he",
      "description": "אוצר הכתבים הגנוזים — איסוף, תרגום והנגשה של ספרות יהודית ויהודו-נוצרית קדומה.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "{{ site.origin }}{{ site.pathPrefix }}search/?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
    </script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "LOGIA — אוצר הכתבים הגנוזים",
      "url": "{{ site.origin }}{{ site.pathPrefix }}",
      "logo": "{{ ogImageUrl }}",
      "description": "אוצר הכתבים הגנוזים — איסוף, תרגום והנגשה של ספרות יהודית ויהודו-נוצרית קדומה.",
      "sameAs": []
    }
    </script>
    {% endif %}

    {# Fonts: self-hosted Frank Ruhl Libre + Noto Serif Hebrew + EB Garamond (Latin display) #}
    {% if fonts.useSelfHosted and fonts.selfHostedStylesheet %}
    <link rel="stylesheet" href="{{ fonts.selfHostedStylesheet | url }}">
    {% elif fonts.loadExternal %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Frank+Ruhl+Libre:wght@300;400;700&family=Noto+Serif+Hebrew:wght@300;400;700&family=EB+Garamond:wght@400;500;700&display=swap" rel="stylesheet">
    {% endif %}
    <link rel="stylesheet" href="{{ '/assets/style.css' | url }}">
    <link rel="preload" as="image" href="{{ '/assets/og-image.png' | url }}" type="image/png">
    <link rel="icon" type="image/svg+xml" href="{{ '/assets/favicon.svg' | url }}">
    <link rel="icon" type="image/png" sizes="192x192" href="{{ '/assets/favicon-192.png' | url }}" loading="lazy">
    <link rel="icon" type="image/png" sizes="512x512" href="{{ '/assets/favicon-512.png' | url }}" loading="lazy">
    <link rel="icon" type="image/x-icon" href="{{ '/assets/favicon.ico' | url }}">
    <link rel="apple-touch-icon" sizes="180x180" href="{{ '/assets/apple-touch-icon.png' | url }}">
    <link rel="mask-icon" href="{{ '/assets/favicon.svg' | url }}" color="#8B6F3A">
</head>
<body class="{{ bodyClass }}">
    <a class="skip-link" href="#main-content">דלג לתוכן</a>

    <button id="readingModeToggle" class="reading-mode-toggle icon-btn" type="button" aria-pressed="false" aria-label="הפעלת מצב קריאה" aria-description="מצב קריאה כבוי. לחיצה תפעיל מצב קריאה להצגת התוכן ללא הסחות." title="מצב קריאה" data-reading-label-on="כיבוי מצב קריאה" data-reading-label-off="הפעלת מצב קריאה" data-reading-description-on="מצב קריאה פעיל. לחיצה תכבה את מצב הקריאה ותחזיר את כל רכיבי הממשק." data-reading-description-off="מצב קריאה כבוי. לחיצה תפעיל מצב קריאה להצגת התוכן ללא הסחות.">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
        <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
      </svg>
      <span class="sr-only" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;">הפעלת או כיבוי מצב קריאה</span>
    </button>

    <script>
      window.siteRuntimeConfig = {
        fonts: {
          provider: "{{ fonts.provider or 'system' }}",
          loadExternal: {{ "true" if fonts.loadExternal else "false" }},
          useSelfHosted: {{ "true" if fonts.useSelfHosted else "false" }},
          selfHostedStylesheet: "{{ fonts.selfHostedStylesheet or '' }}",
          fallbackStack: "{{ fonts.fallbackStack or '' }}"
        },
        thirdParty: {
          analytics: {
            enabled: {{ "true" if analytics.enabled else "false" }},
            measurementId: "{{ analytics.measurementId or '' }}"
          },
          clarity: {
            enabled: {{ "true" if clarity.enabled else "false" }},
            projectId: "{{ clarity.projectId or '' }}"
          },
          disqus: {
            enabled: {{ "true" if disqus.enabled else "false" }},
            shortname: "{{ disqus.shortname or site.disqusShortname or '' }}"
          },
          translate: {
            enabled: {{ "true" if translate.enabled else "false" }},
            includedLanguages: "{{ translate.includedLanguages or 'en' }}"
          }
        }
      };
    </script>

    <header>
        <div class="header-top">
            <a href="{{ '/' | url }}" class="site-brand">
              <span class="site-brand__mark" aria-hidden="true">{% include "logo-mark.njk" %}</span>
              <span class="site-brand__text">
                <span class="site-brand__name">LOGIA</span>
                <span class="site-brand__tagline">אוצר הכתבים הגנוזים</span>
              </span>
            </a>

            <div class="header-controls">
              <form class="header-search" role="search" action="{{ '/search/' | url }}" method="get">
                <label for="headerSearchInput" class="sr-only">חיפוש באוצר</label>
                <input
                  id="headerSearchInput"
                  class="header-search__input"
                  type="search"
                  name="q"
                  placeholder="חיפוש בכתבים…"
                  autocomplete="off"
                  aria-label="חיפוש בכתבים">
                <button class="header-search__btn" type="submit" aria-label="חיפוש">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="11" cy="11" r="8"/>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                  </svg>
                </button>
              </form>
              <button id="themeToggle" class="icon-btn theme-toggle" aria-label="בחר מצב אור/חושך" aria-pressed="false" title="מצב אור/חושך">
                <svg class="icon-moon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                </svg>
                <svg class="icon-sun" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none;">
                  <circle cx="12" cy="12" r="5"/>
                  <line x1="12" y1="1" x2="12" y2="3"/>
                  <line x1="12" y1="21" x2="12" y2="23"/>
                  <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                  <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                  <line x1="1" y1="12" x2="3" y2="12"/>
                  <line x1="21" y1="12" x2="23" y2="12"/>
                  <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                  <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                </svg>
              </button>
              <button id="mainNavToggle" class="main-nav-toggle" type="button" aria-controls="mainNav" aria-expanded="false" aria-label="פתיחה וסגירה של תפריט הניווט">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                  <line x1="3" y1="6" x2="21" y2="6"/>
                  <line x1="3" y1="12" x2="21" y2="12"/>
                  <line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
              </button>
            </div>
        </div>

        <nav id="mainNav" role="navigation" aria-label="ניווט ראשי">
            <a href="{{ '/' | url }}" {% if page.url == "/" %}aria-current="page"{% endif %}>דף הבית</a>
            <a href="{{ '/updates/' | url }}" {% if page.url == "/updates/" %}aria-current="page"{% endif %}>מה חדש</a>
            <div class="nav-dropdown">
                <a href="{{ '/texts/' | url }}" class="dropbtn" aria-haspopup="true" aria-expanded="false" {% if page.url and page.url.startsWith("/texts/") %}aria-current="page"{% endif %}>לפי מקור</a>
                <div class="dropdown-content">
                    <a href="{{ '/texts/hebrew/' | url }}" {% if page.url == "/texts/hebrew/" %}aria-current="page"{% endif %}>עברית</a>
                    <a href="{{ '/texts/slavic/' | url }}" {% if page.url == "/texts/slavic/" %}aria-current="page"{% endif %}>סלאבית</a>
                    <a href="{{ '/texts/aramaic/' | url }}" {% if page.url == "/texts/aramaic/" %}aria-current="page"{% endif %}>ארמית</a>
                    <a href="{{ '/texts/armenian/' | url }}" {% if page.url == "/texts/armenian/" %}aria-current="page"{% endif %}>ארמנית</a>
                    <a href="{{ '/texts/arabic/' | url }}" {% if page.url == "/texts/arabic/" %}aria-current="page"{% endif %}>ערבית</a>
                    <a href="{{ '/texts/greek/' | url }}" {% if page.url == "/texts/greek/" %}aria-current="page"{% endif %}>יוונית</a>
                    <a href="{{ '/texts/geez/' | url }}" {% if page.url == "/texts/geez/" %}aria-current="page"{% endif %}>געז</a>
                    <a href="{{ '/texts/latin/' | url }}" {% if page.url == "/texts/latin/" %}aria-current="page"{% endif %}>לטינית</a>
                </div>
            </div>

            <div class="nav-dropdown">
                <a href="{{ '/by-figure/' | url }}" class="dropbtn" aria-haspopup="true" aria-expanded="false" {% if page.url and page.url.startsWith("/by-figure/") %}aria-current="page"{% endif %}>לפי ייחוס</a>
                <div class="dropdown-content">
                    <a href="{{ '/by-figure/abraham/' | url }}" {% if page.url == "/by-figure/abraham/" %}aria-current="page"{% endif %}>אברהם</a>
                    <a href="{{ '/by-figure/daniel/' | url }}" {% if page.url == "/by-figure/daniel/" %}aria-current="page"{% endif %}>דניאל</a>
                    <a href="{{ '/by-figure/enoch/' | url }}" {% if page.url == "/by-figure/enoch/" %}aria-current="page"{% endif %}>חנוך</a>
                    <a href="{{ '/by-figure/ezra/' | url }}" {% if page.url == "/by-figure/ezra/" %}aria-current="page"{% endif %}>עזרא</a>
                    <a href="{{ '/by-figure/isaiah/' | url }}" {% if page.url == "/by-figure/isaiah/" %}aria-current="page"{% endif %}>ישעיהו</a>
                    <a href="{{ '/by-figure/zerubbabel/' | url }}" {% if page.url == "/by-figure/zerubbabel/" %}aria-current="page"{% endif %}>זרובבל</a>
                    <a href="{{ '/by-figure/talmidei-yeshua/' | url }}" {% if page.url == "/by-figure/talmidei-yeshua/" %}aria-current="page"{% endif %}>מתלמידי ישוע הנוצרי</a>
                </div>
            </div>
            <a href="{{ '/about/' | url }}" {% if page.url == "/about/" %}aria-current="page"{% endif %}>אודות</a>
            <a href="{{ '/methodology/' | url }}" {% if page.url == "/methodology/" %}aria-current="page"{% endif %}>מתודולוגיה</a>
            <a href="{{ '/contact/' | url }}" {% if page.url == "/contact/" %}aria-current="page"{% endif %}>צור קשר</a>
        </nav>
        {% include "breadcrumbs.njk" %}
    </header>

    <main id="main-content" role="main">
        {% block content %}
            {{ content | safe }}
        {% endblock %}
    </main>

    <footer>
      <div class="footer-inner">

        <div class="footer-brand">
          <span class="footer-brand__mark" aria-hidden="true">{% include "logo-mark.njk" %}</span>
          <div class="footer-brand__text">
            <span class="footer-brand__name">LOGIA</span>
            <span class="footer-brand__tagline">אוצר הכתבים הגנוזים</span>
          </div>
        </div>
        <p class="footer-tagline">השבת קולות עתיקים אל שפת המוצא — שחזורים, תרגומים וביאורים של טקסטים שנדחקו אל שולי המסורת.</p>

        <nav class="footer-nav" aria-label="ניווט בפוטר">
          <div class="footer-nav__col">
            <h4>תוכן</h4>
            <ul>
              <li><a href="{{ '/texts/' | url }}">לפי מקור</a></li>
              <li><a href="{{ '/by-figure/' | url }}">לפי ייחוס</a></li>
              <li><a href="{{ '/search/' | url }}">חיפוש באוצר</a></li>
              <li><a href="{{ '/updates/' | url }}">מה חדש</a></li>
              <li><a href="{{ '/updates/feed.xml' | url }}">פיד RSS</a></li>
            </ul>
          </div>
          <div class="footer-nav__col">
            <h4>המיזם</h4>
            <ul>
              <li><a href="{{ '/about/' | url }}">אודות LOGIA</a></li>
              <li><a href="{{ '/methodology/' | url }}">מתודולוגיה</a></li>
              <li><a href="{{ '/license/' | url }}">רישיון ושימוש</a></li>
              <li><a href="{{ '/privacy/' | url }}">מדיניות פרטיות</a></li>
              <li><a href="{{ '/contact/' | url }}">צור קשר</a></li>
            </ul>
          </div>
          <div class="footer-nav__col">
            <h4>מקורות מובילים</h4>
            <ul>
              <li><a href="{{ '/texts/hebrew/' | url }}">עברית</a></li>
              <li><a href="{{ '/texts/slavic/' | url }}">סלאבית</a></li>
              <li><a href="{{ '/texts/aramaic/' | url }}">ארמית</a></li>
              <li><a href="{{ '/texts/armenian/' | url }}">ארמנית</a></li>
              <li><a href="{{ '/texts/arabic/' | url }}">ערבית</a></li>
              <li><a href="{{ '/texts/greek/' | url }}">יוונית</a></li>
            </ul>
          </div>
        </nav>

        {% if translate.enabled %}
        <div class="footer-tool-group">
            <p class="footer-tool-copy">תרגום מכונה נטען רק אם בוחרים בכך, כדי לחסוך בקשות חיצוניות מיותרות.</p>
            <button id="translateLauncher" class="footer-action" type="button" data-third-party-trigger="translate">
              הפעל תרגום אוטומטי
            </button>
            <div id="google_translate_element" hidden></div>
        </div>
        {% endif %}

        <div class="footer-meta">
          <p>התכנים באתר מופצים בנחלת הכלל (<a href="{{ '/license/' | url }}">CC0 1.0</a>) — ניתן להשתמש, לצטט ולשנות בחופשיות.</p>
          <p class="c-footer-meta">
            &copy; LOGIA — 2025–{{ buildInfo.buildYear }} ·
            <a href="{{ '/sitemap.xml' | url }}">Sitemap</a> ·
            <a href="{{ '/robots.txt' | url }}">Robots</a> ·
            <a href="{{ '/manifest.json' | url }}">Manifest</a>
          </p>
        </div>
      </div>
    </footer>

    <button id="backToTop" class="back-to-top" type="button" aria-label="חזרה לראש העמוד" title="חזרה לראש העמוד">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="12" y1="19" x2="12" y2="5"/>
        <polyline points="5 12 12 5 19 12"/>
      </svg>
    </button>

    <script src="{{ '/assets/js/site.js' | url }}" defer></script>
</body>
</html>
