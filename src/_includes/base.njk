<!DOCTYPE html>
<html lang="he" dir="rtl" id="htmlRoot">
<head>
    {% set sitePrefix = (site.pathPrefix or '/Source/') %}
    {% set fonts = site.fonts or {} %}
    {% set thirdParty = site.thirdParty or {} %}
    {% set analytics = thirdParty.analytics or {} %}
    {% set clarity = thirdParty.clarity or {} %}
    {% set translate = thirdParty.translate or {} %}
    {% set hasConsentControls = (analytics.enabled and analytics.requiresConsent) or (clarity.enabled and clarity.requiresConsent) %}
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | אוצר הכתבים הגנוזים</title>
    
    <!-- Accessibility -->
    <meta name="color-scheme" content="light dark">
    
    <!-- SEO & Meta Tags -->
    <meta name="description" content="{% if description %}{{ description }}{% elif pageNumber and title %}{{ title }} — טקסט ותרגום באתר אוצר הכתבים הגנוזים.{% else %}מסע אל הכתבים הגנוזים והאבודים של המסורת היהודית. תרגומים, ביאורים ועיון בטקסטים שנדחקו אל השוליים.{% endif %}">
    <meta name="keywords" content="כתבים גנוזים, אפוקריפה, ספרים חיצוניים, יהדות, בית שני, מינות, גנוסטיקה, קבלה, מיסטיקה, דניאל, אברהם, זרובבל, עזרא, ישעיהו, אליהו">
    <meta name="author" content="בית המדרש הווירטואלי">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="{{ site.origin }}{{ page.url | url }}">
    
    <!-- Open Graph Tags for Social Media -->
    <meta property="og:type" content="{% if pageNumber == 0 %}book{% else %}article{% endif %}">
    <meta property="og:title" content="{{ title }} | אוצר הכתבים הגנוזים">
    <meta property="og:description" content="{% if description %}{{ description }}{% else %}מסע אל הכתבים הגנוזים והאבודים של המסורת היהודית. תרגומים, ביאורים ועיון בטקסטים שנדחקו אל השוליים.{% endif %}">
    <meta property="og:url" content="{{ site.origin }}{{ page.url | url }}">
    <meta property="og:site_name" content="אוצר הכתבים הגנוזים">
    <meta property="og:locale" content="he_IL">
    <meta property="og:image" content="{{ site.origin }}/Source/assets/og-image.png">
    
    <!-- Twitter/X Tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title }} | אוצר הכתבים הגנוזים">
    <meta name="twitter:description" content="{% if description %}{{ description }}{% else %}מסע אל הכתבים הגנוזים והאבודים של המסורת היהודית. תרגומים, ביאורים ועיון בטקסטים שנדחקו אל השוליים.{% endif %}">
    <meta name="twitter:url" content="{{ site.origin }}{{ page.url | url }}">
    <meta name="twitter:image" content="{{ site.origin }}/Source/assets/og-image.png">
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "{% if pageNumber == 0 %}Book{% else %}Article{% endif %}",
      "name": "{{ title }}",
      "description": "{% if description %}{{ description }}{% else %}מסע אל הכתבים הגנוזים והאבודים של המסורת היהודית. תרגומים, ביאורים ועיון בטקסטים שנדחקו אל השוליים.{% endif %}",
      "url": "{{ site.origin }}{{ page.url | url }}",
      "inLanguage": "he",
      "author": {
        "@type": "Organization",
        "name": "אוצר הכתבים הגנוזים"
      }
    }
    </script>

    {#
      טעינה חיונית בכל עמוד:
      - CSS מקומי, מטא-דאטה ו-site.js.
      טעינה שנדחית/מותנית:
      - Google Translate רק אחרי אינטראקציה מפורשת.
      - Google Analytics + Microsoft Clarity רק אם הופעלו ב-config ורק אחרי consent + אינטראקציה.
      - פונטים חיצוניים רק אם מפעילים אותם במפורש; אחרת מסתמכים על stack מקומי/self-hosted.
    #}
    {% if fonts.useSelfHosted and fonts.selfHostedStylesheet %}
    <link rel="stylesheet" href="{{ fonts.selfHostedStylesheet | url }}">
    {% elif fonts.loadExternal %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Frank+Ruhl+Libre:wght@300;400;700&family=Noto+Serif+Hebrew:wght@300;400;700&display=swap" rel="stylesheet">
    {% endif %}
    <link rel="stylesheet" href="{{ '/assets/style.css' | url }}">
    <link rel="icon" type="image/png" href="{{ '/assets/favicon.png' | url }}">
    <link rel="icon" type="image/x-icon" href="{{ '/assets/favicon.ico' | url }}">
</head>
<body class="{{ bodyClass }}">
    <a class="skip-link" href="#main-content">דלג לתוכן</a>
    <button id="readingModeToggle" class="reading-mode-toggle" type="button" aria-pressed="false" aria-label="הפעלת מצב קריאה" aria-description="מצב קריאה כבוי. לחיצה תפעיל מצב קריאה להצגת התוכן ללא הסחות." title="מצב קריאה" data-reading-label-on="כיבוי מצב קריאה" data-reading-label-off="הפעלת מצב קריאה" data-reading-description-on="מצב קריאה פעיל. לחיצה תכבה את מצב הקריאה ותחזיר את כל רכיבי הממשק." data-reading-description-off="מצב קריאה כבוי. לחיצה תפעיל מצב קריאה להצגת התוכן ללא הסחות."><span aria-hidden="true">📖</span><span style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;">הפעלת או כיבוי מצב קריאה</span></button>
    <script>
      window.siteRuntimeConfig = {
        fonts: {
          provider: "{{ fonts.provider or 'system' }}",
          loadExternal: {{ "true" if fonts.loadExternal else "false" }},
          useSelfHosted: {{ "true" if fonts.useSelfHosted else "false" }},
          selfHostedStylesheet: "{{ fonts.selfHostedStylesheet or '' }}",
          fallbackStack: "{{ fonts.fallbackStack or '' }}"
        },
        thirdParty: {
          consentMode: "{{ thirdParty.consentMode or 'opt-in' }}",
          analytics: {
            enabled: {{ "true" if analytics.enabled else "false" }},
            measurementId: "{{ analytics.measurementId or '' }}",
            requiresConsent: {{ "true" if analytics.requiresConsent else "false" }},
            loadStrategy: "{{ analytics.loadStrategy or 'disabled' }}"
          },
          clarity: {
            enabled: {{ "true" if clarity.enabled else "false" }},
            projectId: "{{ clarity.projectId or '' }}",
            requiresConsent: {{ "true" if clarity.requiresConsent else "false" }},
            loadStrategy: "{{ clarity.loadStrategy or 'disabled' }}"
          },
          translate: {
            enabled: {{ "true" if translate.enabled else "false" }},
            requiresConsent: {{ "true" if translate.requiresConsent else "false" }},
            loadStrategy: "{{ translate.loadStrategy or 'disabled' }}",
            includedLanguages: "{{ translate.includedLanguages or 'en' }}"
          }
        }
      };
    </script>
    <header>
        <div class="header-top">
            <h1><a href="{{ '/' | url }}">אוצר הכתבים הגנוזים</a></h1>
            <button id="themeToggle" class="theme-toggle" aria-label="בחר מצב אור/חושך" aria-pressed="false" title="מצב אור/חושך">🌙</button>
            <button id="mainNavToggle" class="main-nav-toggle" type="button" aria-controls="mainNav" aria-expanded="false" aria-label="פתיחה וסגירה של תפריט הניווט">☰</button>
        </div>
        <nav id="mainNav" role="navigation" aria-label="ניווט ראשי">
            <a href="{{ '/' | url }}" {% if page.url == "/" %}aria-current="page"{% endif %}>דף הבית</a>
            <a href="{{ '/search/' | url }}" {% if page.url == "/search/" %}aria-current="page"{% endif %}><span aria-hidden="true">🔍</span> חיפוש</a>
            <a href="{{ '/updates/' | url }}" {% if page.url == "/updates/" %}aria-current="page"{% endif %}><span aria-hidden="true">🆕</span> מה חדש</a>

            <div class="nav-dropdown">
                <a href="{{ '/texts/' | url }}" class="dropbtn" aria-haspopup="true" aria-expanded="false" {% if page.url and page.url.startsWith("/texts/") %}aria-current="page"{% endif %}>לפי מקור</a>
                <div class="dropdown-content">
                    <a href="{{ '/texts/hebrew/' | url }}" {% if page.url == "/texts/hebrew/" %}aria-current="page"{% endif %}>עברית</a>
                    <a href="{{ '/texts/slavic/' | url }}" {% if page.url == "/texts/slavic/" %}aria-current="page"{% endif %}>סלאבית</a>
                    <a href="{{ '/texts/aramaic/' | url }}" {% if page.url == "/texts/aramaic/" %}aria-current="page"{% endif %}>ארמית</a>
                    <a href="{{ '/texts/armenian/' | url }}" {% if page.url == "/texts/armenian/" %}aria-current="page"{% endif %}>ארמנית</a>
                    <a href="{{ '/texts/arabic/' | url }}" {% if page.url == "/texts/arabic/" %}aria-current="page"{% endif %}>ערבית</a>
                    <a href="{{ '/texts/geez/' | url }}" {% if page.url == "/texts/geez/" %}aria-current="page"{% endif %}>געז</a>
                    <a href="{{ '/texts/latin/' | url }}" {% if page.url == "/texts/latin/" %}aria-current="page"{% endif %}>לטינית</a>
                </div>
            </div>
            
            <div class="nav-dropdown">
                <a href="{{ '/by-figure/' | url }}" class="dropbtn" aria-haspopup="true" aria-expanded="false" {% if page.url and page.url.startsWith("/by-figure/") %}aria-current="page"{% endif %}>לפי ייחוס</a>
                <div class="dropdown-content">
                    <a href="{{ '/by-figure/abraham/' | url }}" {% if page.url == "/by-figure/abraham/" %}aria-current="page"{% endif %}>אברהם</a>
                    <a href="{{ '/by-figure/daniel/' | url }}" {% if page.url == "/by-figure/daniel/" %}aria-current="page"{% endif %}>דניאל</a>
                    <a href="{{ '/by-figure/enoch/' | url }}" {% if page.url == "/by-figure/enoch/" %}aria-current="page"{% endif %}>חנוך</a>
                    <a href="{{ '/by-figure/zerubbabel/' | url }}" {% if page.url == "/by-figure/zerubbabel/" %}aria-current="page"{% endif %}>זרובבל</a>
                    <a href="{{ '/by-figure/talmidei-yeshua/' | url }}" {% if page.url == "/by-figure/talmidei-yeshua/" %}aria-current="page"{% endif %}>מתלמידי ישוע הנוצרי</a>
                </div>
            </div>
        </nav>
        {% include "breadcrumbs.njk" %}
    </header>
    
    <main id="main-content" role="main">
        {% block content %}
            {{ content | safe }}
        {% endblock %}
    </main>
    <footer>
        {% if translate.enabled %}
        <div class="footer-tool-group">
            <p class="footer-tool-copy">תרגום מכונה נטען רק אם בוחרים בכך, כדי לחסוך בקשות חיצוניות מיותרות.</p>
            <button id="translateLauncher" class="footer-action" type="button" data-third-party-trigger="translate">
              הפעל תרגום אוטומטי
            </button>
            <div id="google_translate_element" hidden></div>
        </div>
        {% endif %}

        {% if hasConsentControls %}
        <div class="footer-tool-group footer-tool-group--privacy">
            <p class="footer-tool-copy">שירותי מדידה חיצוניים כבויים כברירת מחדל וייטענו רק אחרי אישור מפורש.</p>
            {% if analytics.enabled and analytics.requiresConsent %}
            <button class="footer-action" type="button" data-consent-service="analytics">אפשר Google Analytics</button>
            {% endif %}
            {% if clarity.enabled and clarity.requiresConsent %}
            <button class="footer-action" type="button" data-consent-service="clarity">אפשר Microsoft Clarity</button>
            {% endif %}
        </div>
        {% endif %}

        <p>&copy; כל הזכויות שמורות - 2025–{{ buildInfo.buildYear }}</p>
        <p class="c-footer-meta">
            <a href="{{ '/sitemap.xml' | url }}">Sitemap</a> | 
            <a href="{{ '/robots.txt' | url }}">Robots</a>
        </p>
    </footer>

    <script src="{{ '/assets/js/site.js' | url }}" defer></script>

</body>
</html>
