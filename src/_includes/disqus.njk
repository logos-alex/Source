{# Disqus Comments — Opt-in Only #}
{# Loads only after explicit user consent, consistent with the site's privacy-first approach #}

<div id="comments-section" class="c-section-divider">
  <h3>תגובות</h3>

  {% if site.disqusShortname %}
    {% set disqusConsent = thirdParty.consentMode or 'opt-in' %}

    <div id="disqus-consent-area">
      <p class="c-muted">מערכת התגובות (Disqus) טוענת סקריפטים חיצוניים וקוקיז. לחצו להפעלה.</p>
      <button class="footer-action" type="button" id="disqusConsentBtn" data-consent-service="disqus">אפשר תגובות (Disqus)</button>
    </div>

    <div id="disqus_thread" style="display:none;"></div>

    <script>
      (function () {
        var consentBtn = document.getElementById('disqusConsentBtn');
        var consentArea = document.getElementById('disqus-consent-area');
        var threadEl = document.getElementById('disqus_thread');
        if (!consentBtn || !threadEl) return;

        function loadDisqus() {
          threadEl.style.display = '';
          if (consentArea) consentArea.style.display = 'none';

          var d = document, s = d.createElement('script');
          s.src = 'https://{{ site.disqusShortname }}.disqus.com/embed.js';
          s.setAttribute('data-timestamp', +new Date());
          s.setAttribute('data-external-service', 'disqus');
          (d.head || d.body).appendChild(s);
        }

        var storedConsent = (function () {
          try {
            var raw = localStorage.getItem('thirdPartyConsent');
            return raw ? JSON.parse(raw) : {};
          } catch { return {}; }
        })();

        if (storedConsent.disqus) {
          loadDisqus();
        } else {
          consentBtn.addEventListener('click', function () {
            try {
              var raw = localStorage.getItem('thirdPartyConsent');
              var state = raw ? JSON.parse(raw) : {};
              state.disqus = true;
              localStorage.setItem('thirdPartyConsent', JSON.stringify(state));
            } catch {}
            loadDisqus();
          });
        }
      })();
    </script>
    <noscript>Please enable JavaScript to view the <a href="https://disqus.com/?ref_noscript">comments powered by Disqus.</a></noscript>
  {% else %}
    <p class="c-muted">מערכת התגובות כבויה כרגע בהגדרות האתר.</p>
  {% endif %}
</div>
