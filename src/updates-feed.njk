---
layout: false
permalink: /updates/feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>LOGIA — מה חדש</title>
    <link>{{ site.origin }}{{ site.pathPrefix }}updates/</link>
    <atom:link href="{{ site.origin }}{{ site.pathPrefix }}updates/feed.xml" rel="self" type="application/rss+xml" />
    <description>עדכונים וחידושים במאגר LOGIA — אוצר הכתבים הגנוזים.</description>
    <language>he</language>
    <lastBuildDate>{{ buildInfo.builtAtUTC }}</lastBuildDate>
    {% for item in updates.items.slice(0, 10) %}
    <item>
      <title>{{ item.title }}</title>
      <link>{{ site.origin }}{{ site.pathPrefix }}updates/#{{ item.id }}</link>
      <guid isPermaLink="false">logia-update-{{ item.id }}</guid>
      <description>{{ item.summary }}</description>
      <category>{{ item.category }}</category>
      {% if item.pubDateRFC822 %}<pubDate>{{ item.pubDateRFC822 }}</pubDate>{% elif item.dateLabel %}<pubDate>{{ item.dateLabel }}</pubDate>{% endif %}
    </item>
    {% endfor %}
  </channel>
</rss>
