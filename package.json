{
  "name": "logia",
  "version": "1.0.0",
  "description": "LOGIA — אוצר הכתבים הגנוזים. Hebrew digital archive of apocryphal and pseudepigraphical texts.",
  "private": true,
  "main": ".eleventy.js",
  "scripts": {
    "dev": "eleventy --serve --port=5000 --pathprefix=/Source/",
    "build": "npm run build:eleventy && npm run build:assets && npm run build:search",
    "build:eleventy": "eleventy --pathprefix=/Source/",
    "build:assets": "npm run build:css && npm run build:js",
    "build:css": "csso src/assets/style.css --output _site/assets/style.css",
    "build:js": "terser src/assets/js/site.js -c -m -o _site/assets/js/site.js",
    "build:search": "pagefind --site _site --output-path _site/pagefind",
    "test": "npm run ci:verify",
    "check:frontmatter": "node scripts/verify-frontmatter.mjs",
    "check:pathprefix": "node scripts/verify-path-prefix.mjs",
    "ci:verify": "node scripts/ci-verify.mjs",
    "check:texts": "node scripts/verify-text-structure.mjs",
    "check:permalinks": "node scripts/verify-permalinks.mjs",
    "check:placeholders": "node scripts/verify-placeholders.mjs",
    "check:built-links": "node scripts/verify-built-links.mjs",
    "check:intro-navigation": "node scripts/verify-intro-navigation.mjs",
    "new:chapter": "node scripts/new-chapter.mjs",
    "check:catalog": "node scripts/verify-catalog-consistency.mjs",
    "check:chapter-titles": "node scripts/verify-chapter-titles.mjs",
    "report:content": "node scripts/report-content-status.mjs",
    "check:content-report": "node scripts/report-content-status.mjs --check",
    "check:release-content": "node scripts/verify-release-content.mjs",
    "check:intro-revisions": "node scripts/verify-intro-revisions.mjs",
    "check:display-book-titles": "node scripts/verify-display-book-titles.mjs",
    "check:third-party": "node scripts/verify-third-party-controls.mjs",
    "audit": "npm audit --audit-level=high --omit=dev || true",
    "lint": "prettier --check \"**/*.{js,mjs,cjs,json,njk,css,md,yml}\" --ignore-path .gitignore",
    "format": "prettier --write \"**/*.{js,mjs,cjs,json,njk,css,md,yml}\" --ignore-path .gitignore"
  },
  "keywords": [
    "eleventy",
    "apocrypha",
    "pseudepigrapha",
    "hebrew",
    "static-site",
    "archive"
  ],
  "author": "LOGIA Project",
  "license": "CC0-1.0",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "csso-cli": "^4.0.2",
    "gh-pages": "^6.3.0",
    "js-yaml": "^5.1.0",
    "pagefind": "^1.4.0",
    "prettier": "^3.4.2",
    "terser": "^5.37.0"
  },
  "overrides": {
    "@11ty/recursive-copy": "4.0.3"
  },
  "packageManager": "npm@10.9.0"
}
