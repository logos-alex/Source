# Normalize line endings to LF in the repository
* text=auto eol=lf

# Markdown sources — treat as text (LF)
*.md text eol=lf

# Templates and config
*.njk text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.html text eol=lf
*.txt text eol=lf

# Binary assets — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.wasm binary
*.pf_fragment binary
*.pf_index binary
*.pf_ref binary
